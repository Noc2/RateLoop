# Disposable tokenless-v2 Base Sepolia deployment only.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=

# The disposable Base Sepolia deployment may use a regular nonzero EOA here.
# Keep it separate from the initial admission signer when practical.
TOKENLESS_ROTATION_AUTHORITY=
TOKENLESS_INITIAL_SIGNER=
TOKENLESS_MAX_SCHEDULED_GRACE=86400
