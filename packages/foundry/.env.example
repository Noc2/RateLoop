# Template for foundry environment variables.

# For local development, copy this file, rename it to .env, and fill in the values.

# We provide default values so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# Live-network deploys use a Foundry keystore selected via:
#   yarn deploy --network <network> --keystore <name>

# Alchemy rpc URL is used while deploying the contracts to some testnets/mainnets, checkout `foundry.toml` for its use.
# Get your free API key at https://www.alchemy.com/
ALCHEMY_API_KEY=
# Optional: override World Chain RPCs for deploys. Recommended for reliable live/testnet broadcasts.
WORLDCHAIN_RPC_URL=
WORLDCHAIN_SEPOLIA_RPC_URL=
# World ID v4 app/action used by RaterRegistry deploys.
NEXT_PUBLIC_WORLD_ID_APP_ID=
NEXT_PUBLIC_WORLD_ID_CREDENTIAL_ACTION=rateloop-human-credential-v1
NEXT_PUBLIC_WORLD_ID_PRESENCE_ACTION=rateloop-human-presence-v1
# World Chain mainnet uses the bundled production v4 verifier by default.
# Use `yarn deploy --network worldchain --world-id-staging-canary --keystore <name>`
# for the one-time mainnet canary with the World ID staging verifier. The wrapper
# sets RATELOOP_MAINNET_CANARY, RATELOOP_DEPLOYMENT_PROFILE, and
# WORLD_ID_V4_VERIFIER_ADDRESS for that canary mode.
#
# World Chain Sepolia auto-deploys MockWorldIDVerifier when no live v4 verifier
# has code at the configured address.
# Optional explicit Sepolia v4 verifier override; nonzero overrides must already
# be deployed on the selected chain. Mainnet overrides must match the selected
# deploy mode.
# WORLD_ID_V4_VERIFIER_ADDRESS=
# RATELOOP_MAINNET_CANARY=
# RATELOOP_DEPLOYMENT_PROFILE=
# Numeric RP ID and issuer schema ID from the World Developer Portal.
WORLD_ID_V4_RP_ID=
WORLD_ID_V4_ISSUER_SCHEMA_ID=
# Optional lower bound for accepted v4 credential genesis issuance timestamps.
WORLD_ID_V4_CREDENTIAL_GENESIS_ISSUED_AT_MIN=0
# Etherscan API key is used only for Etherscan-compatible verification flows.
# Get your free API key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
# Localhost deploys use the standard Anvil private key directly and do not need a keystore password.
