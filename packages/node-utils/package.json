{
  "name": "@rateloop/node-utils",
  "version": "0.1.0",
  "type": "module",
  "description": "Bounded Foundry V3 keystore loading for RateLoop Node services",
  "homepage": "https://github.com/Noc2/RateLoop/tree/main/packages/node-utils",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noc2/RateLoop.git",
    "directory": "packages/node-utils"
  },
  "bugs": {
    "url": "https://github.com/Noc2/RateLoop/issues"
  },
  "keywords": [
    "rateloop",
    "node",
    "foundry",
    "keystore"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./keystore": {
      "types": "./dist/esm/keystore.d.ts",
      "import": "./dist/esm/keystore.js",
      "require": "./dist/cjs/keystore.js"
    },
    "./aws-kms-secp256k1": {
      "types": "./dist/esm/aws-kms-secp256k1.d.ts",
      "import": "./dist/esm/aws-kms-secp256k1.js",
      "require": "./dist/cjs/aws-kms-secp256k1.js"
    }
  },
  "typesVersions": {
    "*": {
      "keystore": [
        "dist/esm/keystore.d.ts"
      ],
      "aws-kms-secp256k1": [
        "dist/esm/aws-kms-secp256k1.d.ts"
      ],
      "*": [
        "dist/esm/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "node ../../scripts/with-workspace-dist-lock.mjs \"node ../../scripts/clean-package-dist.mjs && yarn build:dist\"",
    "build:dist": "tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist/esm && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package-json.mjs dist/cjs",
    "prepack": "yarn build",
    "test": "node ../../scripts/run-node-tests.mjs src",
    "check-types": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
