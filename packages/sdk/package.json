{
  "name": "@rateloop/sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "Tokenless quote, ask, wait, and result client for RateLoop integrations",
  "homepage": "https://github.com/Noc2/RateLoop/tree/main/packages/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noc2/RateLoop.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Noc2/RateLoop/issues"
  },
  "keywords": [
    "rateloop",
    "tokenless",
    "sdk",
    "human-evaluation",
    "agent-api"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/with-workspace-dist-lock.mjs \"node ../../scripts/clean-package-dist.mjs && tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist/esm && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package-json.mjs dist/cjs\"",
    "check-types": "tsc --noEmit",
    "prepack": "yarn build",
    "test": "node ../../scripts/run-node-tests.mjs src"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
