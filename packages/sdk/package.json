{
  "name": "@curyo/sdk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Framework-agnostic frontend SDK foundations for Curyo integrations",
  "homepage": "https://github.com/Noc2/CURYO/tree/main/packages/sdk",
