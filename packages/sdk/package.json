{
  "name": "@rateloop/sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "Framework-agnostic frontend SDK foundations for RateLoop integrations",
  "homepage": "https://github.com/Noc2/RateLoop/tree/main/packages/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noc2/RateLoop.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Noc2/RateLoop/issues"
  },
  "keywords": [
    "rateloop",
    "sdk",
    "frontend",
    "reputation",
    "viem"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "agent": [
        "dist/esm/agent.d.ts"
      ],
      "client": [
        "dist/esm/client.d.ts"
      ],
      "config": [
        "dist/esm/config.d.ts"
      ],
      "errors": [
        "dist/esm/errors.d.ts"
      ],
      "read": [
        "dist/esm/read.d.ts"
      ],
      "types": [
        "dist/esm/types.d.ts"
      ],
      "vote": [
        "dist/esm/vote.d.ts"
      ],
      "*": [
        "dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./agent": {
      "types": "./dist/esm/agent.d.ts",
      "import": "./dist/esm/agent.js",
      "require": "./dist/cjs/agent.js"
    },
    "./client": {
      "types": "./dist/esm/client.d.ts",
      "import": "./dist/esm/client.js",
      "require": "./dist/cjs/client.js"
    },
    "./config": {
      "types": "./dist/esm/config.d.ts",
      "import": "./dist/esm/config.js",
      "require": "./dist/cjs/config.js"
    },
    "./errors": {
      "types": "./dist/esm/errors.d.ts",
      "import": "./dist/esm/errors.js",
      "require": "./dist/cjs/errors.js"
    },
    "./read": {
      "types": "./dist/esm/read.d.ts",
      "import": "./dist/esm/read.js",
      "require": "./dist/cjs/read.js"
    },
    "./types": {
      "types": "./dist/esm/types.d.ts",
      "import": "./dist/esm/types.js",
      "require": "./dist/cjs/types.js"
    },
    "./vote": {
      "types": "./dist/esm/vote.d.ts",
      "import": "./dist/esm/vote.js",
      "require": "./dist/cjs/vote.js"
    }
  },
  "scripts": {
    "build:workspace-deps": "yarn workspace @rateloop/contracts build",
    "build": "yarn build:workspace-deps && node ../../scripts/clean-package-dist.mjs && tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist/esm && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package-json.mjs dist/cjs",
    "check-types": "yarn build:workspace-deps && tsc --noEmit",
    "prepack": "yarn build",
    "test": "yarn build:workspace-deps && node ../../scripts/run-node-tests.mjs src"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@rateloop/contracts": "workspace:*",
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
