{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "rootDir": "."
  },
  "include": [
    "ponder-env.d.ts",
    "ponder.schema.ts",
    "src/api/**/*.ts",
    "src/streak-utils.ts",
    "src/urlCanonicalization.ts"
  ],
  "exclude": ["node_modules"]
}
