# Copy this file to .env.local and fill in the deployment-specific values.
# For supported chains, `yarn deploy --network <network>` also refreshes these address and start-block values.

# Production services, especially PONDER_NETWORK=base, must run with NODE_ENV=production.
# NODE_ENV=production

# Active network to index
PONDER_NETWORK=hardhat
# Optional explicit chain ID override; must match PONDER_NETWORK when both are set.
# Used by `yarn ponder:start` for protocol deployment keys and schema selection.
# PONDER_CHAIN_ID=31337

# RPC endpoints. Base Sepolia (84532), Base mainnet (8453), World Chain Sepolia (4801),
# and World Chain mainnet (480) MUST be set when the matching PONDER_NETWORK is active
# and `NODE_ENV=production`.
#
# Do NOT point at Alchemy's free public endpoint (`worldchain-{mainnet,sepolia}.g.alchemy.com/public`):
# its `eth_getLogs` block range is capped at 10 blocks on the free tier, which stalls Ponder's
# initial backfill for hours. Use one of:
#   * Alchemy Pay-as-You-Go (https://www.alchemy.com/chains/world-chain)
#   * Goldsky (https://goldsky.com/)
#   * Tenderly Node (https://tenderly.co/web3-gateway)
#   * QuickNode (https://www.quicknode.com/chains/world-chain)
#   * Your own archive node
PONDER_RPC_URL_31337=http://127.0.0.1:8545
PONDER_RPC_URL_84532=
PONDER_RPC_URL_8453=
PONDER_RPC_URL_4801=
PONDER_RPC_URL_480=

# Contract addresses. Local Hardhat reads these overrides from .env.local. Supported live chains
# ignore stale env addresses and use shared @rateloop/contracts deployment artifacts instead.
PONDER_CONTENT_REGISTRY_ADDRESS=
PONDER_ROUND_VOTING_ENGINE_ADDRESS=
PONDER_ROUND_REWARD_DISTRIBUTOR_ADDRESS=
PONDER_CATEGORY_REGISTRY_ADDRESS=
PONDER_PROFILE_REGISTRY_ADDRESS=
PONDER_FRONTEND_REGISTRY_ADDRESS=
PONDER_LREP_ADDRESS=
PONDER_LAUNCH_DISTRIBUTION_POOL_ADDRESS=
PONDER_CLUSTER_PAYOUT_ORACLE_ADDRESS=
PONDER_ADVISORY_VOTE_RECORDER_ADDRESS=
PONDER_QUESTION_REWARD_POOL_ESCROW_ADDRESS=
PONDER_FEEDBACK_BONUS_ESCROW_ADDRESS=
PONDER_FEEDBACK_REGISTRY_ADDRESS=
PONDER_RATER_REGISTRY_ADDRESS=
PONDER_CONFIDENTIALITY_ESCROW_ADDRESS=

# Start blocks. Local-only fallback when the active chain has no shared deployment metadata.
PONDER_CONTENT_REGISTRY_START_BLOCK=0
PONDER_ROUND_VOTING_ENGINE_START_BLOCK=0
PONDER_ROUND_REWARD_DISTRIBUTOR_START_BLOCK=0
PONDER_CATEGORY_REGISTRY_START_BLOCK=0
PONDER_PROFILE_REGISTRY_START_BLOCK=0
PONDER_FRONTEND_REGISTRY_START_BLOCK=0
PONDER_LREP_START_BLOCK=0
PONDER_LAUNCH_DISTRIBUTION_POOL_START_BLOCK=0
PONDER_CLUSTER_PAYOUT_ORACLE_START_BLOCK=0
PONDER_ADVISORY_VOTE_RECORDER_START_BLOCK=0
PONDER_QUESTION_REWARD_POOL_ESCROW_START_BLOCK=0
PONDER_FEEDBACK_BONUS_ESCROW_START_BLOCK=0
PONDER_FEEDBACK_REGISTRY_START_BLOCK=0
PONDER_RATER_REGISTRY_START_BLOCK=0
PONDER_CONFIDENTIALITY_ESCROW_START_BLOCK=0

# Database (RECOMMENDED for production — omit to use PGlite, which is dev-only)
# Ponder auto-detects: if DATABASE_URL is set, it uses PostgreSQL; otherwise PGlite.
# PGlite is single-process, has no backup tooling, and corruption requires full re-index.
# Use managed PostgreSQL in production (Railway Postgres, Neon, Supabase, etc.)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=
# Optional: use a private/internal URL for database connections (takes precedence over DATABASE_URL)
# DATABASE_PRIVATE_URL=
# Optional break-glass namespace for Ponder tables. Leave unset for normal live
# services: `yarn ponder:start` derives Railway deployment-scoped schemas on
# Railway, protocol deployment-scoped schemas from live deployment artifacts
# elsewhere, and only falls back to RateLoop-owned network schemas when deployment
# metadata is unavailable. Static live overrides require
# RATELOOP_PONDER_ALLOW_LIVE_SCHEMA_OVERRIDE=true and a deliberate recovery plan.
# RATELOOP_PONDER_DATABASE_SCHEMA=rateloop_ponder_manual_recovery_202606
# DATABASE_SCHEMA=

# Allowed browser origins (comma-separated; REQUIRED in production)
CORS_ORIGIN=

# REQUIRED in production: set to the IP header your reverse proxy uses.
# Without this, rate limiting falls back to request fingerprinting which is
# easily bypassed. Examples: x-forwarded-for,cf-connecting-ip,x-real-ip
RATE_LIMIT_TRUSTED_IP_HEADERS=

# HTTPS prefixes Ponder may fetch for payout artifacts published by the keeper.
# Required when the keeper uses KEEPER_CORRELATION_ARTIFACT_STORAGE=file.
# Loopback HTTP artifact URLs are accepted only for PONDER_NETWORK=hardhat.
# Example: https://artifacts.example.com/rateloop/
# Keeper uses KEEPER_ARTIFACT_HTTPS_ALLOWLIST for the same prefix; Ponder accepts that name as an alias.
PAYOUT_ARTIFACT_HTTPS_ALLOWLIST=

# Bearer token required for GET /keeper/work in production (must match keeper PONDER_KEEPER_WORK_TOKEN).
# PONDER_KEEPER_WORK_TOKEN=
# Bearer token required for POST /question-metadata when not explicitly open for local/dev sync.
# Must match the Next.js server PONDER_METADATA_SYNC_TOKEN.
# PONDER_METADATA_SYNC_TOKEN=
# Local/dev only: allow metadata sync without a bearer token.
# PONDER_METADATA_SYNC_ALLOW_OPEN=false
