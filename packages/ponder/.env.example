# Tokenless-v4 only. Historical v1-v3 bundles are rejected.
NODE_ENV=development
# Every production service validates its isolated Railway runtime IDs.
TOKENLESS_HOME_REGION=eu
TOKENLESS_RAILWAY_PROJECT_ID=
TOKENLESS_PONDER_SERVICE_ID=
PONDER_NETWORK=hardhat
# PONDER_CHAIN_ID=31337
PONDER_RPC_URL_31337=http://127.0.0.1:8545
# PONDER_RPC_URL_84532=https://sepolia.base.org
# PONDER_RPC_FALLBACK_URLS_84532=https://independent-base-sepolia-rpc.example

PONDER_TOKENLESS_PANEL_ADDRESS=
PONDER_CREDENTIAL_ISSUER_ADDRESS=
PONDER_FEEDBACK_BONUS_ADDRESS=
PONDER_BEACON_VERIFIER_ADDRESS=
# Optional until X402PanelSubmitter is deployed.
PONDER_X402_PANEL_SUBMITTER_ADDRESS=0x0000000000000000000000000000000000000000
PONDER_TOKENLESS_START_BLOCK=0
# Hosted health fails when indexing trails either bound. Wall-clock age is not enforced on idle hardhat.
TOKENLESS_MAX_INDEX_LAG_BLOCKS=30
TOKENLESS_MAX_INDEX_AGE_SECONDS=120

# Required on Base Sepolia; must equal tokenless-v4:<chainId>:<panel>:<issuer>:<adapter-or-zero>:<feedback-bonus>.
RATELOOP_PONDER_PROTOCOL_DEPLOYMENT_KEY=
# Break-glass only. Mismatched overrides require RATELOOP_PONDER_ALLOW_SCHEMA_OVERRIDE=true.
# RATELOOP_PONDER_DATABASE_SCHEMA=
# RATELOOP_PONDER_ALLOW_SCHEMA_OVERRIDE=false

DATABASE_URL=
DATABASE_PRIVATE_URL=
CORS_ORIGIN=http://localhost:3000
# Required in production for GET /keeper/work.
PONDER_KEEPER_WORK_TOKEN=
