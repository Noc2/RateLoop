{
  "name": "@rateloop/ponder",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/devWithRecovery.mjs",
    "dev:raw": "ponder dev --disable-ui",
