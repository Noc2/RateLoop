{
  "name": "@rateloop/ponder",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:contracts": "yarn workspace @rateloop/contracts build",
    "dev": "yarn build:contracts && node ./scripts/devWithRecovery.mjs",
    "dev:raw": "yarn build:contracts && ponder dev --disable-ui",
    "dev:ui": "yarn build:contracts && ponder dev",
    "start": "yarn build:contracts && node ./scripts/start.mjs",
    "codegen": "yarn build:contracts && ponder codegen",
    "serve": "ponder serve",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rateloop/contracts": "workspace:*",
    "@rateloop/node-utils": "workspace:*",
    "hono": "~4.12.21",
    "ponder": "^1.0.0",
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
