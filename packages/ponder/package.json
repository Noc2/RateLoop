{
  "name": "@rateloop/ponder",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:contracts": "yarn workspace @rateloop/contracts build",
    "build:workspace-deps": "yarn workspace @rateloop/node-utils build:dist && yarn workspace @rateloop/contracts build",
    "ensure:contracts": "node ./scripts/ensureContractsArtifacts.mjs",
    "dev": "yarn build:workspace-deps && node ./scripts/devWithRecovery.mjs",
    "dev:built-contracts": "node ./scripts/devWithRecovery.mjs dev:raw:built-contracts",
    "dev:raw": "yarn build:workspace-deps && ponder dev --disable-ui",
    "dev:raw:built-contracts": "yarn ensure:contracts && ponder dev --disable-ui",
    "dev:ui": "yarn build:workspace-deps && ponder dev",
    "start": "yarn build:workspace-deps && node ./scripts/start.mjs",
    "start:built-contracts": "yarn start:built-workspace-deps",
    "start:built-workspace-deps": "node ./scripts/start.mjs",
    "codegen": "yarn build:workspace-deps && ponder codegen",
    "serve": "ponder serve",
    "check-types": "yarn build:workspace-deps && tsc --noEmit",
    "test": "yarn build:workspace-deps && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rateloop/contracts": "workspace:*",
    "@rateloop/node-utils": "workspace:*",
    "hono": "4.12.25",
    "pg": "^8.11.3",
    "ponder": "^1.0.0",
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "@types/pg": "^8.15.6",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
