# Network (required)
RPC_URL=
CHAIN_ID=

# Contracts (local Hardhat overrides; optional only for unsupported live chains)
# Live supported chains read the latest deployment from @rateloop/contracts.
RATER_DECLARATION_REGISTRY_ADDRESS=

# Optional start block override for declaration scanning.
# PROBER_START_BLOCK=

# Wallet (Foundry keystore — preferred)
KEYSTORE_ACCOUNT=prober
KEYSTORE_PASSWORD=

# Alternatively, raw private key (not recommended)
# PROBER_PRIVATE_KEY=0x...

# Operational identity (optional; when set it must match the signer address)
# PROBER_ROLE_WALLET=

# Prober behavior
PROBER_INTERVAL_MS=30000
PROBER_STARTUP_JITTER_MS=0
PROBER_RECENT_BLOCK_LOOKBACK=5000
PROBER_DECLARATION_SCAN_BATCH_BLOCKS=2000
PROBER_MAX_CANDIDATES_PER_TICK=10

# Detector configuration
PROBER_DETECTOR_KIND=mock
PROBER_DETECTOR_BUNDLE_HASH=0x1111111111111111111111111111111111111111111111111111111111111111
PROBER_PROBE_LIBRARY_HASH=0x2222222222222222222222222222222222222222222222222222222222222222

# Monitoring
METRICS_ENABLED=true
# Use 0.0.0.0 in containers or when exposing metrics remotely.
METRICS_BIND_ADDRESS=127.0.0.1
METRICS_PORT=9091

# Logging ("json" for production, "text" for development)
LOG_FORMAT=json

# Tuning (optional)
# CHAIN_NAME=World Chain
# MIN_GAS_BALANCE_WEI=10000000000000000
# MAX_GAS_PER_TX=750000
