{
  "name": "@rateloop/agents",
  "version": "0.2.0",
  "type": "module",
  "description": "Tokenless quote, ask, wait, and result helpers for RateLoop agents",
  "homepage": "https://github.com/Noc2/RateLoop/tree/main/packages/agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noc2/RateLoop.git",
    "directory": "packages/agents"
  },
  "bugs": {
    "url": "https://github.com/Noc2/RateLoop/issues"
  },
  "keywords": [
    "rateloop",
    "agents",
    "human-feedback",
    "tokenless"
  ],
  "bin": {
    "rateloop-agents": "./dist/esm/cli.js"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "tokenless": [
        "dist/esm/tokenless.d.ts"
      ],
      "*": [
        "dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    ".env.example"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./tokenless": {
      "types": "./dist/esm/tokenless.d.ts",
      "import": "./dist/esm/tokenless.js",
      "require": "./dist/cjs/tokenless.js"
    }
  },
  "scripts": {
    "ask": "tsx src/cli.ts ask",
    "build:workspace-deps": "yarn workspace @rateloop/sdk build",
    "build:built-workspace-deps": "node ../../scripts/with-workspace-dist-lock.mjs \"node ../../scripts/clean-package-dist.mjs && tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist/esm && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package-json.mjs dist/cjs\"",
    "build": "yarn build:workspace-deps && yarn build:built-workspace-deps",
    "check-types": "yarn build:workspace-deps && tsc --noEmit",
    "prepack": "yarn build",
    "quote": "tsx src/cli.ts quote",
    "result": "tsx src/cli.ts result",
    "test": "yarn build && vitest run",
    "test:watch": "vitest",
    "wait": "tsx src/cli.ts wait"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@rateloop/sdk": "workspace:*",
    "dotenv": "^16.4.5",
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
