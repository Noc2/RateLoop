{
  "name": "@rateloop/agents",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent-facing CLI, templates, and question helpers for RateLoop integrations",
  "homepage": "https://github.com/Noc2/RateLoop/tree/main/packages/agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noc2/RateLoop.git",
    "directory": "packages/agents"
  },
  "bugs": {
    "url": "https://github.com/Noc2/RateLoop/issues"
  },
  "keywords": [
    "rateloop",
    "agents",
    "mcp",
    "human-feedback"
  ],
  "bin": {
    "rateloop-agents": "./dist/esm/cli.js"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "lint": [
        "dist/esm/questions/lint.d.ts"
      ],
      "question-specs": [
        "dist/esm/questionSpecs.d.ts"
      ],
      "questions": [
        "dist/esm/questions/index.d.ts"
      ],
      "templates": [
        "dist/esm/templates.d.ts"
      ],
      "x402-question-payload": [
        "dist/esm/x402QuestionPayload.d.ts"
      ],
      "*": [
        "dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    ".env.example"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./lint": {
      "types": "./dist/esm/questions/lint.d.ts",
      "import": "./dist/esm/questions/lint.js",
      "require": "./dist/cjs/questions/lint.js"
    },
    "./question-specs": {
      "types": "./dist/esm/questionSpecs.d.ts",
      "import": "./dist/esm/questionSpecs.js",
      "require": "./dist/cjs/questionSpecs.js"
    },
    "./questions": {
      "types": "./dist/esm/questions/index.d.ts",
      "import": "./dist/esm/questions/index.js",
      "require": "./dist/cjs/questions/index.js"
    },
    "./templates": {
      "types": "./dist/esm/templates.d.ts",
      "import": "./dist/esm/templates.js",
      "require": "./dist/cjs/templates.js"
    },
    "./x402-question-payload": {
      "types": "./dist/esm/x402QuestionPayload.d.ts",
      "import": "./dist/esm/x402QuestionPayload.js",
      "require": "./dist/cjs/x402QuestionPayload.js"
    }
  },
  "scripts": {
    "ask": "tsx src/cli.ts ask",
    "build": "yarn workspace @rateloop/node-utils build:dist && node ../../scripts/clean-package-dist.mjs && tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist/esm && tsc -p tsconfig.cjs.json && node ../../scripts/write-cjs-package-json.mjs dist/cjs",
    "check-types": "yarn workspace @rateloop/node-utils build:dist && tsc --noEmit",
    "lint:questions": "tsx src/cli.ts lint",
    "local-ask": "tsx src/cli.ts local-ask",
    "prepack": "yarn build",
    "quote": "tsx src/cli.ts quote",
    "result": "tsx src/cli.ts result",
    "sandbox": "tsx src/cli.ts sandbox",
    "status": "tsx src/cli.ts status",
    "templates": "tsx src/cli.ts templates",
    "wallet": "tsx src/cli.ts wallet",
    "test": "yarn build && vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@rateloop/contracts": "workspace:*",
    "@rateloop/node-utils": "workspace:*",
    "@rateloop/sdk": "workspace:*",
    "dotenv": "^16.4.5",
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
