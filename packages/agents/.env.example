# Hosted RateLoop origin used by SDK HTTP and MCP flows.
RATELOOP_API_BASE_URL=https://rateloop.example

# Wallet address used by tokenless public asks. Fund it with World Chain USDC.
RATELOOP_AGENT_WALLET_ADDRESS=

# Optional Unix timestamp in seconds for example ask reward windows.
RATELOOP_REWARD_POOL_EXPIRES_AT=1893456000

# RPC used by `yarn workspace @rateloop/agents local-ask` to send returned transactionPlan calls.
RATELOOP_RPC_URL=

# Optional guard. If set, local-ask refuses to transact when the RPC reports a different chain.
RATELOOP_CHAIN_ID=

# Encrypted local signer keystore. Prefer this over raw private-key environment variables.
RATELOOP_LOCAL_SIGNER_KEYSTORE_PATH=
RATELOOP_LOCAL_SIGNER_KEYSTORE_PASSWORD=

# Ephemeral CI escape hatch only. Prefer the encrypted keystore above for persistent agent wallets.
RATELOOP_LOCAL_SIGNER_PRIVATE_KEY=

# Optional managed agent bearer token. Configure scopes and budget caps in the app.
RATELOOP_MCP_TOKEN=

# Optional MCP endpoint override. Tokenless clients default to ${RATELOOP_API_BASE_URL}/api/mcp/public.
RATELOOP_MCP_API_URL=

# Optional MCP protocol version override.
RATELOOP_MCP_PROTOCOL_VERSION=
