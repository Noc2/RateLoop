# Required. Use the isolated tokenless Vercel deployment URL, never the legacy rateloop.ai service.
RATELOOP_API_BASE_URL=https://your-tokenless-preview.vercel.app

# Optional scoped key for prepaid ask/wait/result calls. Free quotes omit this header.
RATELOOP_AGENT_API_KEY=

# Optional API prefix. The SDK defaults to /api/agent/v1.
RATELOOP_AGENT_API_PATH=/api/agent/v1

# Optional default timeout for quote, ask, and result HTTP requests.
RATELOOP_REQUEST_TIMEOUT_MS=10000
