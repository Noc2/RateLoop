{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rateloop-tokenless.vercel.app/schemas/rateloop-host-output-release-evidence.v2.json",
  "title": "RateLoop signed host output release evidence v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "keyId", "payload", "signature"],
  "properties": {
    "schemaVersion": { "const": "rateloop.host-output-release-evidence.v2" },
    "keyId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "releaseId",
        "workspaceId",
        "integrationId",
        "opportunityId",
        "decision",
        "terminalStatus",
        "releaseDisposition",
        "resultSemantics",
        "resultOutcome",
        "resultCommitment",
        "outputCommitment",
        "policyBindingHash",
        "scopeCommitment",
        "hostBindingCommitment",
        "issuedAt",
        "expiresAt"
      ],
      "properties": {
        "schemaVersion": { "const": "rateloop.host-output-release-payload.v2" },
        "releaseId": { "$ref": "#/$defs/opaqueId" },
        "workspaceId": { "$ref": "#/$defs/opaqueId" },
        "integrationId": { "$ref": "#/$defs/opaqueId" },
        "opportunityId": { "$ref": "#/$defs/opaqueId" },
        "decision": { "enum": ["satisfied", "skipped"] },
        "terminalStatus": { "enum": ["completed", "skipped"] },
        "releaseDisposition": {
          "enum": ["authorized_positive", "selection_skipped"]
        },
        "resultSemantics": { "enum": ["assurance", "feedback"] },
        "resultOutcome": {
          "type": ["string", "null"],
          "enum": ["positive", null]
        },
        "resultCommitment": {
          "anyOf": [{ "$ref": "#/$defs/commitment" }, { "type": "null" }]
        },
        "outputCommitment": { "$ref": "#/$defs/commitment" },
        "policyBindingHash": { "$ref": "#/$defs/commitment" },
        "scopeCommitment": { "$ref": "#/$defs/commitment" },
        "hostBindingCommitment": { "$ref": "#/$defs/commitment" },
        "issuedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "decision": { "const": "skipped" } },
            "required": ["decision"]
          },
          "then": {
            "properties": {
              "terminalStatus": { "const": "skipped" },
              "releaseDisposition": { "const": "selection_skipped" },
              "resultOutcome": { "type": "null" },
              "resultCommitment": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "decision": { "const": "satisfied" } },
            "required": ["decision"]
          },
          "then": {
            "properties": {
              "terminalStatus": { "const": "completed" },
              "releaseDisposition": { "const": "authorized_positive" },
              "resultSemantics": { "const": "assurance" },
              "resultOutcome": { "const": "positive" },
              "resultCommitment": { "$ref": "#/$defs/commitment" }
            }
          }
        }
      ]
    },
    "signature": { "type": "string", "pattern": "^[A-Za-z0-9_-]{86}$" }
  },
  "$defs": {
    "opaqueId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{8,200}$" },
    "commitment": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
