# Network (required)
RPC_URL=
# Supported: 31337 (Hardhat local), 4801 (World Chain Sepolia), 480 (World Chain mainnet).
CHAIN_ID=

# Contracts (local Hardhat overrides; optional only for unsupported live chains)
# Live supported chains read the latest deployment from @rateloop/contracts.
VOTING_ENGINE_ADDRESS=
CONTENT_REGISTRY_ADDRESS=
ADVISORY_VOTE_RECORDER_ADDRESS=
ROUND_REWARD_DISTRIBUTOR_ADDRESS=
FRONTEND_REGISTRY_ADDRESS=
CLUSTER_PAYOUT_ORACLE_ADDRESS=

# Wallet (Foundry keystore — preferred)
KEYSTORE_ACCOUNT=keeper
KEYSTORE_PASSWORD=

# Alternatively, raw private key (not recommended)
# KEEPER_PRIVATE_KEY=0x...

# Keeper behavior
KEEPER_INTERVAL_MS=30000
PONDER_BASE_URL=http://localhost:42069
# Max blocks the eth_getLogs ciphertext fallback scans backwards when Ponder is
# unavailable or its index is missing a commit (default ~7 days at 2s blocks).
# KEEPER_LOG_FALLBACK_LOOKBACK_BLOCKS=300000
KEEPER_STARTUP_JITTER_MS=0
KEEPER_CLEANUP_BATCH_SIZE=25
# Optional Postgres URL used for keeper-only cache/locks. On Railway, set this to
# a reference to the attached Postgres service's DATABASE_URL.
# KEEPER_DATABASE_URL=postgresql://postgres:postgres@postgres.railway.internal:5432/railway

# Monitoring
METRICS_ENABLED=true
# Leave unset on Railway so the keeper listens on Railway's injected PORT. Set explicitly for
# local Docker or non-Railway hosts.
# METRICS_PORT=9090
# Use 0.0.0.0 in containers or when exposing public file-backed correlation artifacts. Hosted
# automatic file artifact mode defaults to 0.0.0.0 when PORT is present. Non-loopback binds
# REQUIRE METRICS_AUTH_TOKEN below (>=16 chars). Loopback binds may leave METRICS_AUTH_TOKEN empty.
METRICS_BIND_ADDRESS=127.0.0.1
# Bearer token checked on every /metrics + /health request when METRICS_BIND_ADDRESS is
# non-loopback. Generate with e.g. `openssl rand -hex 32`. Must be at least 16 chars or the
# keeper refuses to start. Use unauthenticated /live for public host liveness checks.
# METRICS_AUTH_TOKEN=

# Logging ("json" for production, "text" for development)
LOG_FORMAT=json

# Tuning (optional)
# CHAIN_NAME=World Chain
# DORMANCY_PERIOD=2592000
# MIN_GAS_BALANCE_WEI=10000000000000000
# MAX_GAS_PER_TX=2000000

# Frontend-fee ops (optional)
# KEEPER_FRONTEND_FEE_ENABLED=true
# KEEPER_FRONTEND_ADDRESS=
# KEEPER_FRONTEND_FEE_LOOKBACK_ROUNDS=8
# KEEPER_FRONTEND_FEE_WITHDRAW=true

# Correlation snapshot publication (optional)
# KEEPER_CORRELATION_SNAPSHOTS_ENABLED=true
# KEEPER_CORRELATION_SNAPSHOTS_MODE=auto
# KEEPER_CORRELATION_ARTIFACT_STORAGE=data-uri
# KEEPER_CORRELATION_SNAPSHOT_MAX_ROUNDS_PER_TICK=20
# KEEPER_CORRELATION_SNAPSHOT_PUBLIC_BASE_URL=https://artifacts.example.com/rateloop
# KEEPER_CORRELATION_SNAPSHOT_STORAGE_DIR=./correlation-artifacts
# KEEPER_CORRELATION_SNAPSHOT_ARTIFACT_PATH=./correlation-snapshots.json
# Ponder must allow this same HTTPS prefix via PAYOUT_ARTIFACT_HTTPS_ALLOWLIST.
