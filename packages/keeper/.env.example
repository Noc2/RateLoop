# Tokenless-v4 Base Sepolia deployment (required after a fresh deployment)
NODE_ENV=production
# Every hosted worker must match the isolated Railway project/service runtime IDs.
TOKENLESS_HOME_REGION=eu
TOKENLESS_RAILWAY_PROJECT_ID=
TOKENLESS_KEEPER_SERVICE_ID=
CHAIN_ID=84532
RPC_URL=
# Ordered, comma-separated independent fallbacks. At least one is required in production.
RPC_FALLBACK_URLS=
TOKENLESS_PANEL_ADDRESS=
TOKENLESS_BEACON_VERIFIER_ADDRESS=
TOKENLESS_CREDENTIAL_ISSUER_ADDRESS=
TOKENLESS_FEEDBACK_BONUS_ADDRESS=
# Optional until X402PanelSubmitter is deployed; omitted means the zero address
# in TOKENLESS_DEPLOYMENT_KEY.
TOKENLESS_X402_PANEL_SUBMITTER_ADDRESS=
# tokenless-v4:<chainId>:<panel>:<issuer>:<x402-or-zero>:<feedback-bonus>
TOKENLESS_DEPLOYMENT_KEY=
TOKENLESS_DEPLOYMENT_BLOCK=
# Authenticated event-derived work priority feed; direct chain scanning remains the outage fallback.
TOKENLESS_PONDER_URL=
PONDER_KEEPER_WORK_TOKEN=

# Production transaction signer: a dedicated gas-only secp256k1 AWS KMS key.
# The exact key ARN, recovered Ethereum address, IAM role, and EU region are
# verified before use. AWS_WEB_IDENTITY_TOKEN_FILE must point to a runtime-
# refreshed OIDC token; the SDK exchanges it for short-lived role credentials.
TOKENLESS_KEEPER_KMS_KEY_RESOURCE=
TOKENLESS_KEEPER_KMS_EXPECTED_ADDRESS=
TOKENLESS_KEEPER_KMS_REGION=eu-central-1
TOKENLESS_KEEPER_KMS_ROLE_ARN=
# Optional compatibility value; when present it must match the role above.
AWS_ROLE_ARN=
AWS_WEB_IDENTITY_TOKEN_FILE=/var/run/secrets/rateloop/aws-oidc-token
# TOKENLESS_KEEPER_KMS_ROLE_SESSION_NAME=rateloop-tokenless-keeper

# Local development/test only. Production rejects these and all static AWS
# access-key environment variables.
# KEYSTORE_ACCOUNT=tokenless-keeper
# KEYSTORE_PASSWORD=
# KEEPER_PRIVATE_KEY=0x...

# Permissionless orchestration bounds
KEEPER_INTERVAL_MS=15000
KEEPER_MAX_ROUNDS_PER_TICK=100
KEEPER_SETTLEMENT_BATCH_SIZE=25
KEEPER_MAX_CIPHERTEXT_BYTES=16384
KEEPER_MAX_FEEDBACK_BONUS_POOLS_PER_TICK=100
MIN_GAS_BALANCE_WEI=1000000000000000

# Hosted health and metrics
# Railway injects PORT. /live and status-only /ready are public; /health and /metrics require this token.
METRICS_AUTH_TOKEN=
# METRICS_BIND_ADDRESS=0.0.0.0
# METRICS_PORT=9090
LOG_FORMAT=json
