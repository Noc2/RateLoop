{
  "name": "@rateloop/keeper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:workspace-deps": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn workspace @rateloop/node-utils build:dist\"",
    "build": "tsc -p tsconfig.json",
    "check-types": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn build:workspace-deps && tsc --noEmit\"",
    "start": "yarn build:workspace-deps && yarn build && yarn start:built-dist",
    "start:built-workspace-deps": "yarn build && yarn start:built-dist",
    "start:built-dist": "NODE_ENV=production node dist/index.js",
    "dev": "yarn build:workspace-deps && tsx watch src/index.ts",
    "dev:built-workspace-deps": "tsx watch src/index.ts",
    "test": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn build:workspace-deps && vitest run\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "3.1090.0",
    "@aws-sdk/credential-provider-web-identity": "3.972.65",
    "@rateloop/node-utils": "workspace:*",
    "dotenv": "^16.4.5",
    "tlock-js": "^0.9.0",
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
