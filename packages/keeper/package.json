{
  "name": "@rateloop/keeper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:workspace-deps": "yarn workspace @rateloop/node-utils build:dist && yarn workspace @rateloop/contracts build",
    "check-types": "yarn build:workspace-deps && tsc --noEmit",
    "start": "yarn build:workspace-deps && tsx src/index.ts",
    "start:built-workspace-deps": "tsx src/index.ts",
    "dev": "yarn build:workspace-deps && tsx watch src/index.ts",
    "build:correlation-artifact": "tsx src/build-correlation-artifact.ts",
    "verify:correlation-artifact": "tsx src/correlation-artifact-verifier.ts",
    "test": "yarn build:workspace-deps && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rateloop/contracts": "workspace:*",
    "@rateloop/node-utils": "workspace:*",
    "dotenv": "^16.4.5",
    "pg": "^8.20.0",
    "tlock-js": "^0.9.0",
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "@types/pg": "^8.15.6",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
