{
  "name": "@rateloop/nextjs",
  "version": "0.1.0",
  "private": true,
  "description": "Isolated tokenless RateLoop web app and v1 agent API",
  "scripts": {
    "analyze": "ANALYZE=true yarn build",
    "build": "node scripts/check-identity-deployment.mjs && node scripts/check-tokenless-production-readiness.mjs && node scripts/migrate-hosted-database.mjs && node ../../scripts/with-workspace-dist-lock.mjs \"yarn build:workspace-deps && rm -rf .next && rm -f node_modules/@rateloop/nextjs ../agents/node_modules/@rateloop/agents ../contracts/node_modules/@rateloop/contracts ../foundry/node_modules/@rateloop/foundry ../keeper/node_modules/@rateloop/keeper ../node-utils/node_modules/@rateloop/node-utils ../ponder/node_modules/@rateloop/ponder ../sdk/node_modules/@rateloop/sdk && next build --turbopack\"",
    "build:workspace-deps": "yarn workspace @rateloop/contracts build && yarn workspace @rateloop/sdk build",
    "check-types": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn build:workspace-deps && rm -rf .next && next typegen && tsc --noEmit --incremental\"",
    "dev": "yarn build:workspace-deps && node scripts/dev-preflight.mjs",
    "dev:built-workspace-deps": "node scripts/dev-preflight.mjs",
    "format": "prettier --write . '!(node_modules|.next)/**/*'",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --ignore-pattern public --ignore-pattern .next --ignore-pattern out",
    "serve": "next start",
    "start": "yarn build:workspace-deps && node scripts/dev-preflight.mjs",
    "vercel": "vercel --build-env YARN_ENABLE_IMMUTABLE_INSTALLS=true --build-env ENABLE_EXPERIMENTAL_COREPACK=1 --build-env VERCEL_TELEMETRY_DISABLED=1",
    "vercel:login": "vercel login",
    "db:generate": "drizzle-kit generate",
    "db:migrate:hosted": "node scripts/migrate-hosted-database.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "evidence:verify": "node scripts/verify-assurance-evidence.mjs",
    "attestation:verify": "node scripts/verify-assurance-attestation.mjs",
    "oscal:check": "node scripts/generate-oscal-component-definition.mjs --check",
    "oscal:generate": "node scripts/generate-oscal-component-definition.mjs",
    "audit:verify": "node scripts/verify-audit-export.mjs",
    "auth:check": "node scripts/check-identity-deployment.mjs --production",
    "test": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn build:workspace-deps && node ../../scripts/run-node-tests.mjs app components config lib utils scripts\""
  },
  "dependencies": {
    "@better-auth/passkey": "1.6.23",
    "@better-auth/scim": "1.6.23",
    "@better-auth/sso": "1.6.23",
    "@rateloop/contracts": "workspace:*",
    "@rateloop/sdk": "workspace:*",
    "@tanstack/react-query": "~5.59.15",
    "@vercel/blob": "2.4.0",
    "@worldcoin/idkit": "4.2.0",
    "@worldcoin/idkit-core": "4.2.1",
    "better-auth": "1.6.23",
    "daisyui": "5.0.9",
    "drizzle-orm": "~0.45.2",
    "gsap": "^3.14.2",
    "next": "~15.5.18",
    "pg": "^8.20.0",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "server-only": "0.0.1",
    "sharp": "^0.34.3",
    "stripe": "22.3.1",
    "thirdweb": "5.120.1",
    "tlock-js": "^0.9.0",
    "viem": "2.39.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "4.0.15",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@trivago/prettier-plugin-sort-imports": "~4.3.0",
    "@types/jsdom": "28.0.3",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.6",
    "@types/react": "~19.2.17",
    "axe-core": "4.11.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "~9.38.0",
    "eslint-config-next": "~15.5.18",
    "eslint-config-prettier": "~10.1.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "~5.2.4",
    "jsdom": "29.1.1",
    "pg-mem": "^3.0.14",
    "postcss": "~8.5.14",
    "prettier": "~3.5.3",
    "tailwindcss": "4.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vercel": "54.18.0"
  },
  "license": "MIT",
  "packageManager": "yarn@3.2.3",
  "engines": {
    "node": ">=24 <25"
  }
}
