{
  "name": "@rateloop/nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true yarn build",
    "build": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn build:workspace-deps && rm -rf .next && next build\"",
    "build:workspace-deps": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn workspace @rateloop/node-utils build:dist && yarn workspace @rateloop/contracts build && yarn workspace @rateloop/sdk build:built-workspace-deps && yarn workspace @rateloop/agents build:built-workspace-deps\"",
    "check-types": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn build:workspace-deps && RATELOOP_E2E_PRODUCTION_BUILD=true NEXT_PUBLIC_RATELOOP_E2E_PRODUCTION_BUILD=true NEXT_PUBLIC_TARGET_NETWORKS=31337 next typegen && tsc --noEmit --incremental\"",
    "dev": "yarn build:workspace-deps && node scripts/dev-preflight.mjs",
    "dev:built-workspace-deps": "node scripts/dev-preflight.mjs",
    "format": "prettier --write . '!(node_modules|.next|contracts)/**/*'",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --ignore-pattern public --ignore-pattern .next --ignore-pattern out --ignore-pattern contracts",
    "perf:pages": "node scripts/measure-pages-performance.mjs",
    "serve": "next start",
    "start": "yarn build:workspace-deps && node scripts/dev-preflight.mjs",
    "vercel": "vercel --build-env YARN_ENABLE_IMMUTABLE_INSTALLS=true --build-env ENABLE_EXPERIMENTAL_COREPACK=1 --build-env VERCEL_TELEMETRY_DISABLED=1",
    "vercel:login": "vercel login",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "node ../../scripts/with-workspace-dist-lock.mjs \"yarn build:workspace-deps && node ../../scripts/run-node-tests.mjs app components config constants contexts hooks lib services utils scripts e2e/helpers e2e/playwright.config.test.ts\"",
    "test:world-id": "node ../../scripts/run-node-tests.mjs app/api/world-id lib/world-id",
    "whitepaper": "tsx scripts/whitepaper/generate.tsx",
    "demo:record": "tsx e2e/scripts/record-demo.ts",
    "e2e": "playwright test --config e2e/playwright.config.ts --project=chromium",
    "e2e:world-id:local": "playwright test --config e2e/playwright.config.ts --project=world-id-mock",
    "e2e:ci:smoke": "playwright test --config e2e/playwright.config.ts --project=ci-smoke",
    "e2e:ci:api": "playwright test --config e2e/playwright.config.ts --project=ci-api",
    "e2e:ci:app": "playwright test --config e2e/playwright.config.ts --project=ci-app",
    "e2e:ci:submit": "playwright test --config e2e/playwright.config.ts --project=ci-submit",
    "e2e:ci:confidential": "playwright test --config e2e/playwright.config.ts --project=ci-confidential-context",
    "e2e:ci:world-id": "playwright test --config e2e/playwright.config.ts --project=world-id-mock",
    "e2e:ci:full": "REQUIRE_E2E_KEEPER=1 playwright test --config e2e/playwright.config.ts --project=chromium --project=settlement --project=settlement-keeper --project=round-cancellation --project=content-dormancy",
    "e2e:ci:lifecycle": "playwright test --config e2e/playwright.config.ts --no-deps --project=settlement --project=round-cancellation --project=content-dormancy",
    "e2e:ci:keeper": "REQUIRE_E2E_KEEPER=1 playwright test --config e2e/playwright.config.ts --project=settlement-keeper",
    "e2e:settlement": "playwright test --config e2e/playwright.config.ts --project=settlement",
    "e2e:settlement:keeper": "REQUIRE_E2E_KEEPER=1 playwright test --config e2e/playwright.config.ts --project=settlement-keeper",
    "e2e:responsive": "playwright test --config e2e/playwright.config.ts --project=responsive-layout",
    "e2e:a11y": "playwright test --config e2e/playwright.config.ts --project=accessibility-axe",
    "e2e:compat": "playwright test --config e2e/playwright.config.ts --project=compat-chromium --project=compat-firefox --project=compat-webkit",
    "e2e:mobile": "playwright test --config e2e/playwright.config.ts --project=mobile-phone --project=mobile-android --project=mobile-tablet",
    "e2e:mobile:phone": "playwright test --config e2e/playwright.config.ts --project=mobile-phone",
    "e2e:mobile:phone:navigation": "playwright test --config e2e/playwright.config.ts --project=mobile-phone --grep 'sidebar hidden|hamburger opens|mobile header still hides|hamburger menu navigation|public mobile menu closes'",
    "e2e:mobile:phone:vote": "playwright test --config e2e/playwright.config.ts --project=mobile-phone --grep 'vote page loads|view filter sheet'",
    "e2e:mobile:phone:pages": "playwright test --config e2e/playwright.config.ts --project=mobile-phone --grep 'ask page form|governance page renders|docs page renders'",
    "e2e:mobile:android": "playwright test --config e2e/playwright.config.ts --project=mobile-android",
    "e2e:mobile:tablet": "playwright test --config e2e/playwright.config.ts --project=mobile-tablet",
    "e2e:full": "REQUIRE_E2E_KEEPER=1 playwright test --config e2e/playwright.config.ts --project=chromium --project=settlement --project=settlement-keeper --project=round-cancellation --project=content-dormancy --project=responsive-layout --project=mobile-phone --project=mobile-android --project=mobile-tablet",
    "e2e:firefox": "playwright test --config e2e/playwright.config.ts --project=compat-firefox",
    "e2e:webkit": "playwright test --config e2e/playwright.config.ts --project=compat-webkit",
    "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "e2e:wallet:base-sepolia": "node e2e/scripts/base-sepolia-wallet.mjs",
    "e2e:preflight": "node e2e/scripts/preflight.mjs",
    "e2e:reset": "bash e2e/scripts/reset-chain.sh"
  },
  "dependencies": {
    "@heroicons/react": "~2.1.5",
    "@rateloop/agents": "workspace:*",
    "@rateloop/contracts": "workspace:*",
    "@rateloop/node-utils": "workspace:*",
    "@rateloop/sdk": "workspace:*",
    "@scaffold-ui/components": "0.1.9",
    "@scaffold-ui/hooks": "0.1.7",
    "@tanstack/react-query": "~5.59.15",
    "@thirdweb-dev/wagmi-adapter": "0.2.208",
    "@vercel/blob": "2.3.0",
    "@wagmi/core": "2.22.1",
    "@worldcoin/idkit": "4.1.4",
    "daisyui": "5.0.9",
    "drizzle-orm": "~0.45.2",
    "framer-motion": "^12.29.2",
    "gsap": "^3.14.2",
    "next": "~15.5.18",
    "next-nprogress-bar": "~2.3.13",
    "pg": "^8.20.0",
    "qrcode": "1.5.4",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "react-hot-toast": "~2.4.0",
    "react-lite-youtube-embed": "^3.3.3",
    "server-only": "0.0.1",
    "sharp": "^0.34.3",
    "thirdweb": "5.120.1",
    "usehooks-ts": "~3.1.0",
    "viem": "2.39.0",
    "wagmi": "2.19.5",
    "zustand": "~5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/postcss": "4.0.15",
    "@trivago/prettier-plugin-sort-imports": "~4.3.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.6",
    "@types/react": "~19.0.7",
    "@xmldom/xmldom": "^0.9.10",
    "abitype": "1.0.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "~9.38.0",
    "eslint-config-next": "~15.5.12",
    "eslint-config-prettier": "~10.1.1",
    "eslint-plugin-prettier": "~5.2.4",
    "mathjax-full": "^3.2.2",
    "pg-mem": "^3.0.14",
    "playwright-core": "1.58.2",
    "postcss": "~8.5.14",
    "prettier": "~3.5.3",
    "tailwindcss": "4.1.3",
    "tsx": "^4.21.0",
    "type-fest": "~4.26.1",
    "typescript": "~5.8.2",
    "vercel": "54.18.0"
  },
  "license": "MIT",
  "packageManager": "yarn@3.2.3",
  "engines": {
    "node": ">=24 <25"
  }
}
