{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "tokenless": false
    }
  },
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/tokenless-maintenance",
      "schedule": "*/5 * * * *"
    }
  ],
  "installCommand": "YARN_ENABLE_IMMUTABLE_INSTALLS=true yarn install --immutable"
}
