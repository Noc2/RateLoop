# Isolated tokenless Next.js deployment

# Public origin of this Vercel deployment. Use the generated *.vercel.app domain;
# do not point the tokenless branch at the existing production interface.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dedicated tokenless Postgres database. Apply drizzle/0000_tokenless_agent_api.sql
# before setting TOKENLESS_SANDBOX_MODE=false.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rateloop_tokenless

# Explicit deterministic simulation. true may fall back to in-process storage if
# Postgres is unavailable. false fails closed and never fabricates a live result.
TOKENLESS_SANDBOX_MODE=true

# Reserved server-only signer for the paid-eligibility voucher implementation.
# Never expose this value through a NEXT_PUBLIC variable.
TOKENLESS_CREDENTIAL_ISSUER_SIGNER_PRIVATE_KEY=

# Base Account uses the public URL in the browser for read-only Wagmi access.
# Authentication verification uses the server-only RPC and supports ERC-6492
# signatures from Base Accounts that have not been deployed yet.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
