# Isolated tokenless Next.js deployment

# Public origin of this Vercel deployment. Use the generated *.vercel.app domain;
# do not point the tokenless branch at the existing production interface.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional notification email delivery through Resend. The sender must be a
# verified Resend domain/address. These values are server-only.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Primary browser authentication. Better Auth is self-hosted in the isolated
# tokenless Postgres database. Email OTP uses the Resend variables above.
# Google and Apple are enabled only when both credentials for that provider exist.
BETTER_AUTH_SECRET=
BETTER_AUTH_PASSKEY_RP_ID=localhost
BETTER_AUTH_GOOGLE_CLIENT_ID=
BETTER_AUTH_GOOGLE_CLIENT_SECRET=
BETTER_AUTH_APPLE_CLIENT_ID=
BETTER_AUTH_APPLE_CLIENT_SECRET=

# Optional wallet infrastructure. Ordinary account and workspace use creates no
# wallet. When explicitly enabled, RateLoop issues a five-minute, single-use,
# PII-free Ed25519 JWT for thirdweb, then requires a purpose-bound wallet proof.
# Configure the issuer's JWKS URL as:
#   <APP_URL>/.well-known/rateloop-wallet-jwks.json
TOKENLESS_THIRDWEB_WALLET_ENABLED=false
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
TOKENLESS_THIRDWEB_WALLET_AUDIENCE=
TOKENLESS_THIRDWEB_WALLET_KEY_ID=
# Main-hosted wallet JWTs use a non-exportable Ed25519 KMS key through Vercel
# OIDC. The private JWK fallback is isolated-test-only.
TOKENLESS_THIRDWEB_WALLET_KMS_KEY_RESOURCE=
TOKENLESS_THIRDWEB_WALLET_KMS_REGION=eu-central-1
TOKENLESS_THIRDWEB_WALLET_KMS_ROLE_ARN=
TOKENLESS_THIRDWEB_WALLET_KMS_OIDC_AUDIENCE=https://sts.amazonaws.com
TOKENLESS_THIRDWEB_WALLET_PRIVATE_JWK=

# Dedicated tokenless Postgres database. Apply the complete ordered Drizzle
# journal before starting the application.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rateloop_tokenless

# EU deployment contract. Every hosted deployment must use verified-eu, sign
# the canonical manifest digest, and identify every live
# regional resource and approved external processor. These fields are claim
# gates; setting them without verifying the actual resources is not sufficient.
TOKENLESS_DATA_PLANE_MODE=verified-eu
TOKENLESS_HOME_REGION=eu
TOKENLESS_EU_MANIFEST_SHA256=492ffaeb3a27b58c3692e600679496796830d1299ec38016c14458358fad0184
TOKENLESS_EU_MANIFEST_SIGNING_PUBLIC_KEY=
TOKENLESS_EU_MANIFEST_SIGNATURE=
TOKENLESS_VERCEL_PROJECT_ID=prj_H6C2pfWKEAupFroHbLfzhquaNCLm
TOKENLESS_VERCEL_FUNCTION_REGION=fra1
TOKENLESS_RAILWAY_PROJECT_ID=
TOKENLESS_RAILWAY_REGION=europe-west4-drams3a
TOKENLESS_EU_POSTGRES_RESOURCE_ID=
TOKENLESS_POSTGRES_REGION=europe-west4-drams3a
TOKENLESS_EU_BLOB_STORE_ID=
TOKENLESS_BLOB_REGION=fra1
TOKENLESS_BLOB_ACCESS=private
TOKENLESS_KMS_PROVIDER=
# AWS KMS alias ARN template; at least one tenant placeholder is required.
TOKENLESS_KMS_KEY_RESOURCE=arn:aws:kms:eu-central-1:000000000000:alias/rateloop/{workspaceId}/{projectId}
TOKENLESS_KMS_REGION=eu
TOKENLESS_AWS_KMS_REGION=eu-central-1
TOKENLESS_AWS_KMS_ROLE_ARN=
TOKENLESS_AWS_OIDC_AUDIENCE=https://sts.amazonaws.com
TOKENLESS_KEEPER_SERVICE_ID=
TOKENLESS_KEEPER_REGION=europe-west4-drams3a
TOKENLESS_PONDER_SERVICE_ID=
TOKENLESS_PONDER_REGION=europe-west4-drams3a
TOKENLESS_EU_LOG_SINK_ID=
TOKENLESS_LOG_REGION=eu
TOKENLESS_EU_BACKUP_POLICY_ID=
TOKENLESS_BACKUP_REGION=eu
TOKENLESS_AUTH_DEPLOYMENT_ID=
TOKENLESS_AUTH_REGION=eu
TOKENLESS_SUPPORT_ACCESS_POLICY_ID=
TOKENLESS_SUPPORT_ACCESS_REGION=eu
TOKENLESS_EMAIL_PROCESSOR_EVIDENCE_ID=
# Resend dispatches the verified domain from Ireland, but its account metadata,
# logs, and API records remain in the US. Keep this explicit transfer in the
# processor inventory and DPA/TIA; this setting is not an EU-residency claim.
TOKENLESS_EMAIL_DELIVERY_REGION=eu-west-1
TOKENLESS_BILLING_PROCESSOR_EVIDENCE_ID=
TOKENLESS_ANALYTICS_PROCESSOR_EVIDENCE_ID=
TOKENLESS_RPC_PROCESSOR_EVIDENCE_ID=

# MCP requests are limited by an HMAC of the caller bearer token or trusted
# proxy IP. Use at least 32 random characters and never expose it publicly.
TOKENLESS_MCP_RATE_LIMIT_SECRET=
# Dedicated 32-byte base64url or hex HMAC key for staged-image browser preview grants.
TOKENLESS_PUBLIC_MEDIA_PREVIEW_SECRET=

# Adaptive-review sampling is keyed so opportunities are deterministic and
# auditable without making future sample selection predictable to agents. Use
# a dedicated 32-byte base64url/hex key and rotate only with a new version.
TOKENLESS_ADAPTIVE_REVIEW_SAMPLER_KEY=
TOKENLESS_ADAPTIVE_REVIEW_SAMPLER_KEY_VERSION=sampler-v1

# Private human-assurance artifacts require the managed KMS provider and key
# resource above. Tests inject local fixtures directly; hosted configuration
# must never contain a local master key. Private Vercel Blob storage uses
# server-only token/OIDC configuration. Never add public variants.
TOKENLESS_ARTIFACT_KEY_VERSION=artifact-v1
BLOB_READ_WRITE_TOKEN=

# Dedicated 32-byte base64url/hex key for artifact commitments in managed-vault
# mode. Store it as a server-only managed secret; never add a NEXT_PUBLIC variant
# and never reuse a KMS wrapping key or any reviewer pseudonym keyring value.
TOKENLESS_PSEUDONYM_KEY=

# Reviewer rationales and reviewer-to-run pseudonyms use separate, versioned,
# server-only key domains. Each JSON keyring maps a version to an unrelated
# 32-byte base64url key. Keep retired keys available for replay verification.
TOKENLESS_ASSURANCE_RATIONALE_VAULT_KEY_VERSION=v1
TOKENLESS_ASSURANCE_RATIONALE_VAULT_KEYS={}
TOKENLESS_ASSURANCE_REVIEWER_MAPPING_KEY_VERSION=v1
TOKENLESS_ASSURANCE_REVIEWER_MAPPING_KEYS={}

# Public rater feedback has its own AES-256-GCM keyring. Do not reuse the
# assurance rationale keys and never add a NEXT_PUBLIC variant.
TOKENLESS_PUBLIC_RATER_RESPONSE_VAULT_KEY_VERSION=v1
TOKENLESS_PUBLIC_RATER_RESPONSE_VAULT_KEYS={}

# Private decision packets use a dedicated AWS KMS P-256 signing key through
# Vercel OIDC. The key ID must equal p256:<first 24 hex chars of SHA-256(SPKI
# DER)>. Tenant IDs use an unrelated 32-byte commitment key.
TOKENLESS_EVIDENCE_SIGNING_KEY_ID=
TOKENLESS_EVIDENCE_KMS_KEY_RESOURCE=
TOKENLESS_EVIDENCE_KMS_REGION=eu-central-1
TOKENLESS_EVIDENCE_KMS_ROLE_ARN=
TOKENLESS_EVIDENCE_KMS_OIDC_AUDIENCE=https://sts.amazonaws.com
# Publish the current and retained packet-verification SPKI keys without any
# private material. Exactly one matching current entry is required.
TOKENLESS_DECISION_PACKET_VERIFICATION_KEYS=[]
# Optional verification-only JSON keyring for the current public key and
# retained public keys after rotation. Entries are
# {"algorithm":"Ed25519","keyId":"ed25519:<fingerprint>","publicKey":"<base64url SPKI DER>","status":"current|retired"}.
TOKENLESS_EVIDENCE_VERIFICATION_KEYS=
TOKENLESS_EVIDENCE_TENANT_COMMITMENT_KEY=

# Optional externally witnessed attestations. The private signing key remains
# inside the named AWS KMS Ed25519 key. The KMS public key must also appear as a
# current entry in TOKENLESS_EVIDENCE_VERIFICATION_KEYS so the public keyring
# anchors signer identity across rotations. The credential JSON maps the opaque
# sec_... reference to short-lived AWS access credentials and is server-only.
TOKENLESS_ATTESTATION_KMS_KEY_ARN=
TOKENLESS_ATTESTATION_KMS_REGION=
TOKENLESS_ATTESTATION_AWS_CREDENTIAL_REFERENCE=
TOKENLESS_ATTESTATION_AWS_CREDENTIALS_JSON=
TOKENLESS_ATTESTATION_REKOR_URL=
TOKENLESS_ATTESTATION_REKOR_PUBLIC_KEY_PEM=
TOKENLESS_ATTESTATION_TSA_URL=
TOKENLESS_ATTESTATION_TSA_CA_PEM=
TOKENLESS_ATTESTATION_TSA_UNTRUSTED_PEM=
TOKENLESS_INTEGRITY_REVIEWER_LOOKUP_KEY_VERSION=
TOKENLESS_INTEGRITY_REVIEWER_LOOKUP_KEY=

# Every hosted EVM role uses a distinct non-exportable secp256k1 AWS KMS key,
# expected address, and Vercel-OIDC IAM role. Local private-key variables remain
# available only for isolated tests and must not be configured in production.
TOKENLESS_CREDENTIAL_ISSUER_KMS_KEY_RESOURCE=
TOKENLESS_CREDENTIAL_ISSUER_KMS_EXPECTED_ADDRESS=
TOKENLESS_CREDENTIAL_ISSUER_KMS_REGION=eu-central-1
TOKENLESS_CREDENTIAL_ISSUER_KMS_ROLE_ARN=
TOKENLESS_CREDENTIAL_ISSUER_KMS_OIDC_AUDIENCE=https://sts.amazonaws.com

# Base Account remains an optional external funding/payout wallet. These RPCs
# support Base Sepolia reads and ERC-6492 signature verification where needed.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Ordered, comma-separated independent server-side fallbacks. At least one is required when hosted.
BASE_SEPOLIA_RPC_FALLBACK_URLS=
# Optional Base Account paymaster for funder-side transaction gas.
NEXT_PUBLIC_BASE_PAYMASTER_URL=

# Complete live tokenless deployment identity. These values are replaced
# together after a fresh Base Sepolia deployment; mixed bundles fail closed.
TOKENLESS_DEPLOYMENT_SCHEMA=rateloop-tokenless-deployment-v4
TOKENLESS_CHAIN_ID=84532
TOKENLESS_DEPLOYMENT_KEY=
TOKENLESS_DEPLOYMENT_BLOCK=
TOKENLESS_PANEL_ADDRESS=
TOKENLESS_CREDENTIAL_ISSUER_ADDRESS=
TOKENLESS_X402_PANEL_SUBMITTER_ADDRESS=
TOKENLESS_FEEDBACK_BONUS_ADDRESS=
TOKENLESS_BEACON_VERIFIER_ADDRESS=
TOKENLESS_USDC_ADDRESS=
TOKENLESS_USDC_EIP712_NAME=RateLoop Tokenless Test USDC
TOKENLESS_USDC_EIP712_VERSION=2

# RateLoop interface economics and immutable round timing policy. The reveal
# window cannot be shorter than the panel's five-minute floor.
TOKENLESS_FEE_RECIPIENT=
TOKENLESS_REVEAL_WINDOW_SECONDS=300
TOKENLESS_BEACON_FAILURE_GRACE_SECONDS=21600
TOKENLESS_CLAIM_GRACE_PERIOD_SECONDS=604800

# The x402 role pays gas only; the prepaid funder holds prepaid USDC; the
# surprise-bonus funder holds only its separately reserved pool.
TOKENLESS_X402_RELAYER_KMS_KEY_RESOURCE=
TOKENLESS_X402_RELAYER_KMS_EXPECTED_ADDRESS=
TOKENLESS_X402_RELAYER_KMS_REGION=eu-central-1
TOKENLESS_X402_RELAYER_KMS_ROLE_ARN=
TOKENLESS_X402_RELAYER_KMS_OIDC_AUDIENCE=https://sts.amazonaws.com
TOKENLESS_PREPAID_FUNDER_KMS_KEY_RESOURCE=
TOKENLESS_PREPAID_FUNDER_KMS_EXPECTED_ADDRESS=
TOKENLESS_PREPAID_FUNDER_KMS_REGION=eu-central-1
TOKENLESS_PREPAID_FUNDER_KMS_ROLE_ARN=
TOKENLESS_PREPAID_FUNDER_KMS_OIDC_AUDIENCE=https://sts.amazonaws.com
TOKENLESS_SURPRISE_BONUS_FUNDER_KMS_KEY_RESOURCE=
TOKENLESS_SURPRISE_BONUS_FUNDER_KMS_EXPECTED_ADDRESS=
TOKENLESS_SURPRISE_BONUS_FUNDER_KMS_REGION=eu-central-1
TOKENLESS_SURPRISE_BONUS_FUNDER_KMS_ROLE_ARN=
TOKENLESS_SURPRISE_BONUS_FUNDER_KMS_OIDC_AUDIENCE=https://sts.amazonaws.com
# Non-secret keeper signer inventory is repeated here so the release preflight
# can prove cross-service key, address, and IAM-principal separation.
TOKENLESS_KEEPER_KMS_KEY_RESOURCE=
TOKENLESS_KEEPER_KMS_EXPECTED_ADDRESS=
TOKENLESS_KEEPER_KMS_REGION=eu-central-1
TOKENLESS_KEEPER_KMS_ROLE_ARN=
# Evidence publication must use exactly one finality policy. Hosted Base uses the safe head.
TOKENLESS_EVIDENCE_FINALITY_BLOCK_TAG=safe
# Alternative for RPCs without safe/finalized tags; minimum 64. Leave unset when the block tag is configured.
TOKENLESS_EVIDENCE_CONFIRMATION_DEPTH=

# Paid-task eligibility provider handoff and separately encrypted evidence,
# tax-record, and vote-mapping domains. Use unrelated keys for every domain.
TOKENLESS_ELIGIBILITY_PROVIDER_ID=
TOKENLESS_ELIGIBILITY_PROVIDER_PUBLIC_KEY=
TOKENLESS_ELIGIBILITY_PROVIDER_START_URL=
TOKENLESS_ELIGIBILITY_HANDOFF_SECRET=
TOKENLESS_PROVIDER_EVIDENCE_VAULT_KEY_VERSION=v1
TOKENLESS_PROVIDER_EVIDENCE_VAULT_KEYS={}
TOKENLESS_TAX_VAULT_KEY_VERSION=v1
TOKENLESS_TAX_VAULT_KEYS={}
TOKENLESS_VOTE_MAPPING_VAULT_KEY_VERSION=v1
TOKENLESS_VOTE_MAPPING_VAULT_KEYS={}
TOKENLESS_DAC7_POLICY=eu
TOKENLESS_DAC7_REQUIRED_COUNTRIES=
TOKENLESS_VOUCHER_ISSUER_EPOCH=

# Optional conventional B2B workspace subscriptions. Hosted Stripe Checkout
# does not need a browser key. Keep the secret, webhook secret, and server-side
# Price mapping out of NEXT_PUBLIC variables.
TOKENLESS_SUBSCRIPTIONS_ENABLED=false
TOKENLESS_PREPAID_TOPUP_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_EARLY_ACCESS_MONTHLY_PRICE_ID=
# USD-only customer-balance funding invoice settings.
STRIPE_PREPAID_TOPUP_TAX_CODE=
STRIPE_PREPAID_TOPUP_BANK_TRANSFER_TYPE=us_bank_transfer

# Optional enterprise SSO/SCIM. OIDC issuer origins must be HTTPS origins
# without paths. SCIM tokens and provider secrets remain in the database.
TOKENLESS_ENTERPRISE_IDENTITY_ENABLED=false
TOKENLESS_SSO_TRUSTED_ISSUERS=

# Optional RateLoop-network assurance. World ID 4 is used only for a
# one-time proof-of-human enrollment; it does not replace current liveness,
# legal, sanctions, tax, or payout eligibility. All keys below are server-only.
TOKENLESS_NETWORK_PANELS_ENABLED=false
# Server-only HMAC keyring used to choose undisclosed calibration items. Each value is 32 bytes, base64url.
TOKENLESS_GOLD_INJECTION_KEY_VERSION=v1
TOKENLESS_GOLD_INJECTION_KEYS={"v1":"replace-with-32-byte-base64url-key"}
# Comma-separated authenticated account subjects authorized to verify network expertise evidence.
TOKENLESS_EXPERTISE_OPERATOR_ACCOUNTS=
WORLD_ID_APP_ID=
WORLD_ID_RP_ID=
WORLD_ID_RP_SIGNING_KEY=
WORLD_ID_PROOF_OF_HUMAN_ACTION_VERSION=world-poh-v1
WORLD_ID_PROOF_OF_HUMAN_ACTION=
WORLD_ID_ENVIRONMENT=production
TOKENLESS_PROVIDER_SUBJECT_HMAC_KEY_VERSION=v1
TOKENLESS_PROVIDER_SUBJECT_HMAC_KEYS={}
TOKENLESS_WORLD_ID_EVIDENCE_KEY_VERSION=v1
TOKENLESS_WORLD_ID_EVIDENCE_KEYS={}
TOKENLESS_WORLD_ID_CREDENTIAL_MIN_TTL_SECONDS=2592000

# Server-only transparency pipeline/cron authorization and webhook-secret wrapping.
# Generate unrelated random values; the encryption key is 32 random bytes in
# base64url form. None may be exposed through a NEXT_PUBLIC variable.
TOKENLESS_PIPELINE_TOKEN=
CRON_SECRET=
TOKENLESS_NOTIFICATION_UNSUBSCRIBE_SECRET=
TOKENLESS_PONDER_URL=
TOKENLESS_WEBHOOK_ENCRYPTION_KEY=

# Optional S3 Object Lock delivery. Store this JSON only in the hosting
# provider's encrypted server-side secret store. Workspace records contain only
# opaque sec_... references. Add non-AWS S3-compatible endpoint suffixes here.
TOKENLESS_WORM_S3_CREDENTIALS_JSON=
TOKENLESS_WORM_S3_ALLOWED_ENDPOINT_SUFFIXES=

# Map opaque vault://, kms://, or secret:// GRC references to server-only Drata
# or Vanta credentials. Never expose this map through NEXT_PUBLIC_ variables.
TOKENLESS_GRC_CREDENTIALS_JSON=
