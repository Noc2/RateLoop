# Template for NextJS environment variables.
# Copy this file to .env.local and fill in the values.
# When deploying, store these in Vercel/system env config.

# Target chains (comma-separated chain IDs, in priority order)
# Development default: local Foundry
# Base Sepolia test deploy: 84532
# Base mainnet deploy: 8453
# Override in Vercel/system env config when deploying a live chain.
NEXT_PUBLIC_TARGET_NETWORKS=31337

# RPC provider (get your own at https://dashboard.alchemyapi.io)
# Also used for optional mainnet ENS resolution in the wallet UI.
NEXT_PUBLIC_ALCHEMY_API_KEY=
# Optional per-chain RPC overrides for browser reads and wallet add-chain config.
# Use ordinary sealed-block RPCs here; Ponder/Keeper have separate RPC env vars.
NEXT_PUBLIC_RPC_URL_31337=
NEXT_PUBLIC_RPC_URL_84532=
NEXT_PUBLIC_RPC_URL_8453=
NEXT_PUBLIC_RPC_URL_4801=
NEXT_PUBLIC_RPC_URL_480=
# Optional Base Flashblocks/preconfirmation browser UX. Leave Ponder and Keeper on sealed-block RPCs.
NEXT_PUBLIC_USE_BASE_PRECONF_RPC=false
NEXT_PUBLIC_BASE_PRECONF_RPC_URL_84532=
NEXT_PUBLIC_BASE_PRECONF_RPC_URL_8453=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
# Thirdweb config is for wallet, top-up, and sponsorship features, not the default preconfirmation RPC.
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
THIRDWEB_SERVER_VERIFIER_SECRET=
FREE_TRANSACTION_LIMIT=25

# Optional World ID human credential.
# Configure these from https://developer.world.org after creating an app/action.
NEXT_PUBLIC_WORLD_ID_APP_ID=
NEXT_PUBLIC_WORLD_ID_CREDENTIAL_ACTION=rateloop-human-credential-v1
NEXT_PUBLIC_WORLD_ID_ENVIRONMENT=production
NEXT_PUBLIC_WORLD_ID_PROOF_MODE=legacy
# Used only to sign short-lived World ID widget requests. The credential proof
# is submitted by the user's wallet to RaterRegistry's World ID methods.
# Use the public IDKit RP ID from the World Developer Portal, e.g. rp_...
# Do not use the app_... app ID or the numeric on-chain verifier RP ID here.
WORLD_ID_RP_ID=
WORLD_ID_SIGNING_KEY=

# Optional USDC override for direct agent bounty planning.
# Prefer chain-scoped vars for live multi-chain configs.
RATELOOP_X402_USDC_ADDRESS_84532=
RATELOOP_X402_USDC_ADDRESS_8453=
RATELOOP_X402_USDC_ADDRESS=

# Optional browser-side question bounty overrides.
# Defaults come from @rateloop/contracts and known Circle USDC deployments.
NEXT_PUBLIC_QUESTION_REWARD_POOL_ESCROW_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS_84532=
NEXT_PUBLIC_USDC_ADDRESS_8453=
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_RATELOOP_X402_USDC_ADDRESS_84532=
NEXT_PUBLIC_RATELOOP_X402_USDC_ADDRESS_8453=
NEXT_PUBLIC_RATELOOP_X402_USDC_ADDRESS=

# Remote MCP server for paid agent asks.
# RATELOOP_MCP_AGENTS is a JSON array. Prefer tokenHash (sha256 of the bearer token)
# over raw token values in shared environments.
# Example:
# RATELOOP_MCP_AGENTS=[{"id":"agent-demo","tokenHash":"<sha256>","walletAddress":"0x...","scopes":["rateloop:quote","rateloop:ask","rateloop:read","rateloop:balance"],"dailyBudgetAtomic":"10000000","perAskLimitAtomic":"2000000","categories":["5"]}]
RATELOOP_MCP_AGENTS=
RATELOOP_MCP_ALLOW_UNLIMITED_BUDGET=false
RATELOOP_MCP_ALLOWED_ORIGINS=
RATELOOP_AGENT_CALLBACK_DELIVERY_SECRET=

# Image attachment uploads (optional locally; required for production image hosting)
BLOB_READ_WRITE_TOKEN=
OPENAI_API_KEY=
# Local development override only. Set to "disabled" to bypass uploaded-image moderation.
RATELOOP_IMAGE_MODERATION_MODE=
# Optional local development override for filesystem-backed image uploads when BLOB_READ_WRITE_TOKEN is empty.
RATELOOP_LOCAL_IMAGE_ATTACHMENT_DIR=
# Optional image upload abuse controls. Defaults are 40 images / 200 MB per wallet-day
# and 20 images / 100 MB per MCP agent-day.
RATELOOP_IMAGE_UPLOAD_DAILY_LIMIT=
RATELOOP_IMAGE_UPLOAD_DAILY_BYTES=
RATELOOP_MCP_IMAGE_UPLOAD_DAILY_LIMIT=
RATELOOP_MCP_IMAGE_UPLOAD_DAILY_BYTES=
# Required to call POST /api/attachments/images/sweep for stale unattached upload cleanup.
RATELOOP_IMAGE_ATTACHMENT_SWEEP_SECRET=
# Local development override only. Set to "disabled" to bypass question Details text moderation.
RATELOOP_QUESTION_DETAILS_MODERATION_MODE=
# Required to call POST /api/attachments/details/sweep for stale failed/blocked Details cleanup.
RATELOOP_QUESTION_DETAILS_SWEEP_SECRET=

# Confidential/private context jobs
# Shared bearer/header secret for disclosure reconciliation and log-root publication.
# Vercel Cron sends CRON_SECRET; the RateLoop-specific secret is accepted too when set.
CRON_SECRET=
RATELOOP_CONFIDENTIALITY_JOB_SECRET=
# HMAC secret for confidential context IP hashes and view tokens.
RATELOOP_CONFIDENTIALITY_SECRET=
# Optional public artifact host. Defaults to APP_URL /api/confidentiality/log-roots/:epoch/artifact.
RATELOOP_CONFIDENTIALITY_LOG_ROOT_ARTIFACT_BASE_URL=
# Optional backend wallet key for on-chain log-root anchors.
# The corresponding address must have ConfidentialityEscrow.ACCESS_RECORDER_ROLE.
RATELOOP_CONFIDENTIALITY_LOG_ROOT_ANCHOR_PRIVATE_KEY=

# Email notifications via Resend (optional until email delivery is enabled)
RESEND_API_KEY=
# Must be a verified Resend sender email, for example:
# RESEND_FROM_EMAIL=RateLoop <notifications@info.rateloop.ai>
RESEND_FROM_EMAIL=
APP_URL=http://localhost:3000
NOTIFICATION_DELIVERY_SECRET=

# Database (Postgres for local development and production)
# Use a separate logical database for the Next app, e.g. rateloop_app.
# `yarn dev:db` and `yarn dev:stack` manage a local Docker Postgres instance
# when this URL points to localhost.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rateloop_app
# Trusted proxy headers for API rate limiting in production (comma-separated)
# Required on non-Vercel production hosts when NextRequest.ip is unavailable.
# Vercel auto-trusts x-real-ip.
# Set this only when your hosting proxy overwrites these headers.
# Examples: cf-connecting-ip,x-real-ip
RATE_LIMIT_TRUSTED_IP_HEADERS=

# Foundry keystore — server-side wallet for the Next.js dev faucet
# Name of keystore file in ~/.foundry/keystores/
KEYSTORE_ACCOUNT=
# Password to decrypt the keystore (leave empty to use raw private key fallbacks below)
KEYSTORE_PASSWORD=

# Fallback: raw private key used by the Next.js dev faucet
FAUCET_PRIVATE_KEY=

# Dev-mode faucet — mints LREP, mock USDC, and local identity credentials without document verification
DEV_FAUCET_ENABLED=true

# Ponder Indexer URL (run `yarn ponder:dev` to start locally)
# Required in production and must be publicly reachable by the browser
NEXT_PUBLIC_PONDER_URL=http://localhost:42069

# Allow direct RPC event fallback when Ponder is unavailable
# Keep this disabled in production unless you explicitly accept the RPC load
# NEXT_PUBLIC_ENABLE_RPC_FALLBACK=false

# Frontend operator address for fee distribution (optional)
# NEXT_PUBLIC_FRONTEND_CODE=0x...

# Environment detection (optional, auto-set by hosting platforms)
# Used by getServerEnvironmentScope() to determine "production" vs "preview" vs "development".
# Vercel/Railway inject their own vars automatically; set APP_ENV for other hosts.
# APP_ENV=production
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Build flags (optional)
# NEXT_PUBLIC_IGNORE_BUILD_ERROR=true
# Local production-style E2E only; keep unset for ordinary production/development.
# RATELOOP_E2E_PRODUCTION_BUILD=true
# NEXT_PUBLIC_RATELOOP_E2E_PRODUCTION_BUILD=true
