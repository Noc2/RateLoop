{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rateloop-tokenless.vercel.app/schemas/rateloop-stop-gate-trusted-keys.v1.json",
  "title": "RateLoop Codex Stop gate trusted Ed25519 keys v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "keys"],
  "properties": {
    "schemaVersion": {
      "const": "rateloop.stop-gate-trusted-keys.v1"
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyId", "algorithm", "publicKeyJwk"],
        "properties": {
          "keyId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]{1,128}$"
          },
          "algorithm": {
            "enum": ["Ed25519", "ECDSA-SHA256"]
          },
          "publicKeyJwk": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kty", "crv", "x"],
                "properties": {
                  "kty": { "const": "OKP" },
                  "crv": { "const": "Ed25519" },
                  "x": { "type": "string", "pattern": "^[A-Za-z0-9_-]{43}$" }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kty", "crv", "x", "y"],
                "properties": {
                  "kty": { "const": "EC" },
                  "crv": { "const": "P-256" },
                  "x": { "type": "string", "pattern": "^[A-Za-z0-9_-]{43}$" },
                  "y": { "type": "string", "pattern": "^[A-Za-z0-9_-]{43}$" }
                }
              }
            ]
          }
        }
      }
    }
  }
}
